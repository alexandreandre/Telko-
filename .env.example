# =============================================================================
# Telko — Variables d'environnement
# Copier ce fichier en .env à la racine du dépôt et renseigner les valeurs.
# Le frontend (dossier frontend/) lit les variables VITE_* depuis ce fichier.
# =============================================================================

# --- Frontend (Vite, préfixe VITE_) -----------------------------------------
# Optionnel en dev : absent ou vide = proxy npm vers le backend sur le port 8000
# VITE_API_URL=http://127.0.0.1:8000
# VITE_SUPABASE_URL=https://xxxx.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=eyJ...
# VITE_SUPABASE_PROJECT_ID=xxxx

# --- LLM Provider (ollama | openai | gemini | anthropic | mistral-api | openrouter) ---
LLM_PROVIDER=openrouter
# Timeout HTTP des providers ollama / openrouter / openwebui (secondes). Open WebUI + RAG peut nécessiter 300+.
# LLM_TIMEOUT=120
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=
OPENROUTER_APP_TITLE=Telko
OPENROUTER_LLM_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDINGS_MODEL=openai/text-embedding-3-small

# --- Open WebUI (API externe, compatible OpenAI — optionnel) ------------------
# Si renseigné : entrée « Telko OpenWebUI » dans l’assistant et le comparateur.
OPENWEBUI_BASE_URL=https://votre-openwebui.example.com
OPENWEBUI_API_KEY=
# Identifiant du modèle tel qu’affiché dans Open WebUI (ex. llama3.1)
OPENWEBUI_MODEL=llama3.1
# Chemin sous la base (défaut = endpoint documenté Open WebUI)
# OPENWEBUI_CHAT_PATH=/api/chat/completions
#
# Base de connaissances Open WebUI (RAG côté instance, prioritaire pour « Telko OpenWebUI ») :
# - Le modèle Telko OpenWebUI ne passe jamais par Qdrant Telko ; le RAG est côté Open WebUI uniquement.
# - ID de collection « Knowledge » (dans l’UI Open WebUI) → Telko envoie files=[{type:collection,id:…}] à l’API.
#   Sans ID / JSON : aucun `files` dans le POST ; configurez alors le RAG sur l’instance OW (Knowledge globale, etc.).
# OPENWEBUI_KNOWLEDGE_COLLECTION_ID=
# - Ou JSON complet du tableau `files` (remplace la ligne ci-dessus), ex. :
# OPENWEBUI_CHAT_FILES_JSON=[{"type":"collection","id":"VOTRE_UUID"}]

# Projet Supabase (même URL que VITE_SUPABASE_URL ; clés dans le dashboard)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Clé « anon » / publishable (identique à VITE_SUPABASE_PUBLISHABLE_KEY)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Ollama (ingestion / RAG hors Edge) --------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=mistral
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Qdrant (Vector Store) ----------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=telko_knowledge
QDRANT_API_KEY=

# --- Azure Active Directory (Auth & Graph API) --------------------------------
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# --- SharePoint (Source de documents) ----------------------------------------
SHAREPOINT_SITE_ID=your-sharepoint-site-id
SHAREPOINT_DRIVE_ID=your-sharepoint-drive-id

# --- CORS --------------------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080
